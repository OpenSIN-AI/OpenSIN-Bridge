{
  "manifest_version": 3,
  "name": "OpenSIN Bridge",
  "short_name": "OpenSIN",
  "version": "5.0.0",
  "description": "OpenSIN Bridge - Agent-first browser automation with deterministic verification.",
  "minimum_chrome_version": "120",
  "author": "OpenSIN-AI",
  "homepage_url": "https://opensin.ai",

  "action": {
    "default_title": "OpenSIN Bridge",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "static/icons/16.png",
      "48": "static/icons/48.png",
      "128": "static/icons/128.png"
    }
  },

  "icons": {
    "16": "static/icons/16.png",
    "48": "static/icons/48.png",
    "128": "static/icons/128.png"
  },

  "background": {
    "service_worker": "src/sw.js",
    "type": "module"
  },

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN",
      "js": ["src/content/main-world.js"]
    },
    {
      "matches": ["<all_urls>"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "ISOLATED",
      "js": ["src/content/isolated-world.js"]
    }
  ],

  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "cookies",
    "alarms",
    "offscreen",
    "debugger",
    "webRequest",
    "declarativeNetRequest",
    "nativeMessaging",
    "tabCapture",
    "proxy",
    "notifications"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "optional_permissions": [
    "management"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' https: wss:; img-src 'self' data: blob: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:;"
  },

  "externally_connectable": {
    "matches": [
      "https://*.opensin.ai/*",
      "https://opensin.ai/*",
      "http://localhost:*/*",
      "http://127.0.0.1:*/*"
    ]
  },

  "key": ""
}
