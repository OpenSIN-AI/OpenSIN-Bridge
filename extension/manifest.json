{
    "manifest_version": 3,
    "name": "OpenSIN Bridge",
    "version": "4.0.0",
    "description": "OpenSIN Browser Automation & Auth Platform (Antigravity-Level+)",
    "action": {
        "default_title": "OpenSIN Bridge",
        "default_icon": {
            "16": "static/icons/16.png",
            "48": "static/icons/48.png",
            "128": "static/icons/128.png"
        }
    },
    "background": {
        "service_worker": "background/service_worker.js",
        "type": "module"
    },
    "chrome_url_overrides": {
        "newtab": "static/browserLanding.html"
    },
    "content_scripts": [
        {
            "all_frames": true,
            "js": [
                "content/injector.js"
            ],
            "matches": [
                "<all_urls>"
            ],
            "run_at": "document_start",
            "world": "MAIN"
        }
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self'; connect-src 'self' wss://openjerro-opensin-bridge-mcp.hf.space ws://localhost:*; frame-src http://localhost:*;"
    },
    "externally_connectable": {
        "matches": [
            "https://opensin.ai/*",
            "http://localhost/*",
            "http://127.0.0.1/*"
        ]
    },
    "host_permissions": [
        "<all_urls>"
    ],
    "icons": {
        "16": "static/icons/16.png",
        "48": "static/icons/48.png",
        "128": "static/icons/128.png"
    },
    "key": "",
    "permissions": [
        "activeTab",
        "tabs",
        "webRequest",
        "storage",
        "offscreen",
        "cookies",
        "nativeMessaging",
        "scripting",
        "declarativeNetRequest",
        "alarms",
        "debugger"
    ]
}